app_gui/src/main.cpp.obj:
	$(MAKE) $(MAKESILENT) -f CMakeFiles\Lab4.dir\build.make CMakeFiles/Lab4.dir/app_gui/src/main.cpp.obj
.PHONY : app_gui/src/main.cpp.obj

app_gui/src/main.i: app_gui/src/main.cpp.i
.PHONY : app_gui/src/main.i

# target to preprocess a source file
app_gui/src/main.cpp.i:
	$(MAKE) $(MAKESILENT) -f CMakeFiles\Lab4.dir\build.make CMakeFiles/Lab4.dir/app_gui/src/main.cpp.i
.PHONY : app_gui/src/main.cpp.i

app_gui/src/main.s: app_gui/src/main.cpp.s
.PHONY : app_gui/src/main.s

# target to generate assembly for a file
app_gui/src/main.cpp.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles\Lab4.dir\build.make CMakeFiles/Lab4.dir/app_gui/src/main.cpp.s
.PHONY : app_gui/src/main.cpp.s

